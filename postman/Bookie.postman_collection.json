            "body": { "mode": "raw", "raw": "{\n  \"serviceType\": \"BUS\",\n  \"title\": \"Lahore → Islamabad\",\n  \"originCode\": \"lhe\",\n  \"destinationCode\": \"isb\",\n  \"departAt\": \"2026-06-27T07:00:00+05:00\",\n  \"arriveAt\": \"2026-06-27T11:30:00+05:00\",\n  \"durationMin\": 270,\n  \"price\": 2400,\n  \"priceUnit\": \"per_seat\",\n  \"seatsAvailable\": 30,\n  \"vehicle\": \"Volvo 9700 (Business)\",\n  \"amenities\": [\"wifi\", \"ac\", \"usb\"],\n  \"days\": [\"Mon\", \"Wed\", \"Fri\"],\n  \"routeStops\": [\n    { \"code\": \"lhe\", \"name\": \"Lahore\", \"fare\": 0, \"time\": \"2026-06-27T07:00:00+05:00\" },\n    { \"code\": \"isb\", \"name\": \"Islamabad\", \"fare\": 2400, \"time\": \"2026-06-27T11:30:00+05:00\" }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/operator/trips", "host": ["{{baseUrl}}"], "path": ["operator", "trips"] }
          }
