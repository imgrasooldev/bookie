{
  "info": {
    "name": "Bookie API",
    "_postman_id": "bookie-api-collection-0001",
    "description": "Complete API collection for the Bookie travel platform (apps/api, Express + MongoDB).\n\nBase URL defaults to http://localhost:4000.\n\nAuth model:\n- Customer endpoints use a JWT from /auth/register or /auth/login -> saved to {{customerToken}} automatically.\n- Operator endpoints use a JWT from /operator/register or /operator/login -> saved to {{operatorToken}}.\n- Super-admin (/sa) endpoints need a token whose user has the 'admin' role -> {{adminToken}} (log in via /auth/login with an admin account).\n\nMany requests have test scripts that capture ids (tripId, bookingId, bookingRef, travellerId) into collection variables so you can run them in sequence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "customerToken", "value": "" },
    { "key": "operatorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "tripId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "bookingRef", "value": "" },
    { "key": "bookerPhone", "value": "03001234567" },
    { "key": "travellerId", "value": "" },
    { "key": "operatorId", "value": "" },
    { "key": "cityCode", "value": "lhe" }
  ],
  "item": [
    {
      "name": "Health & Catalog (public)",
      "item": [
        {
          "name": "Health check",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] } }
        },
        {
          "name": "List verticals",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/verticals", "host": ["{{baseUrl}}"], "path": ["verticals"] } }
        },
        {
          "name": "List cities",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/cities", "host": ["{{baseUrl}}"], "path": ["cities"] } }
        },
        {
          "name": "Search trips",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const a = pm.response.json();",
              "if (Array.isArray(a) && a.length) { pm.collectionVariables.set('tripId', a[0].id); }"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/trips?serviceType=BUS&originId=lhe&destinationId=isb&date=2026-06-26&passengers=1",
              "host": ["{{baseUrl}}"],
              "path": ["trips"],
              "query": [
                { "key": "serviceType", "value": "BUS" },
                { "key": "originId", "value": "lhe" },
                { "key": "destinationId", "value": "isb" },
                { "key": "date", "value": "2026-06-26" },
                { "key": "passengers", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get trip by id",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/trips/{{tripId}}", "host": ["{{baseUrl}}"], "path": ["trips", "{{tripId}}"] } }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (customer)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.token) pm.collectionVariables.set('customerToken', r.token);"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ali Raza\",\n  \"phone\": \"03001234567\",\n  \"email\": \"ali@example.com\",\n  \"password\": \"secret1\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login (customer)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.token) pm.collectionVariables.set('customerToken', r.token);"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"identifier\": \"03001234567\",\n  \"password\": \"secret1\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get me",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerToken}}" }] },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Request OTP (stub)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"03001234567\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/otp/request", "host": ["{{baseUrl}}"], "path": ["auth", "otp", "request"] }
          }
        }
      ]
    },
    {
      "name": "Account (customer)",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerToken}}" }] },
      "item": [
        {
          "name": "Get profile",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/account", "host": ["{{baseUrl}}"], "path": ["account"] } }
        },
        {
          "name": "Update profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ali Raza\",\n  \"email\": \"ali@example.com\",\n  \"cnic\": \"3520112345671\",\n  \"dob\": \"1995-04-12\",\n  \"gender\": \"Male\",\n  \"city\": \"Lahore\"\n}" },
            "url": { "raw": "{{baseUrl}}/account/profile", "host": ["{{baseUrl}}"], "path": ["account", "profile"] }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current\": \"secret1\",\n  \"next\": \"secret2\"\n}" },
            "url": { "raw": "{{baseUrl}}/account/password", "host": ["{{baseUrl}}"], "path": ["account", "password"] }
          }
        },
        {
          "name": "Update notification prefs",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"trips\": true,\n  \"promos\": false,\n  \"wallet\": true,\n  \"newsletter\": false\n}" },
            "url": { "raw": "{{baseUrl}}/account/notif-prefs", "host": ["{{baseUrl}}"], "path": ["account", "notif-prefs"] }
          }
        },
        {
          "name": "Get wallet",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/account/wallet", "host": ["{{baseUrl}}"], "path": ["account", "wallet"] } }
        },
        {
          "name": "List travellers",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const a = pm.response.json();",
              "if (Array.isArray(a) && a.length) pm.collectionVariables.set('travellerId', a[a.length-1].id);"
            ], "type": "text/javascript" } }
          ],
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/account/travellers", "host": ["{{baseUrl}}"], "path": ["account", "travellers"] } }
        },
        {
          "name": "Add traveller",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const a = pm.response.json();",
              "if (Array.isArray(a) && a.length) pm.collectionVariables.set('travellerId', a[a.length-1].id);"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Sara Ali\",\n  \"relation\": \"Spouse\",\n  \"cnic\": \"3520199999999\",\n  \"dob\": \"1997-09-03\",\n  \"gender\": \"Female\"\n}" },
            "url": { "raw": "{{baseUrl}}/account/travellers", "host": ["{{baseUrl}}"], "path": ["account", "travellers"] }
          }
        },
        {
          "name": "Update traveller",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"relation\": \"Sister\"\n}" },
            "url": { "raw": "{{baseUrl}}/account/travellers/{{travellerId}}", "host": ["{{baseUrl}}"], "path": ["account", "travellers", "{{travellerId}}"] }
          }
        },
        {
          "name": "Delete traveller",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{baseUrl}}/account/travellers/{{travellerId}}", "host": ["{{baseUrl}}"], "path": ["account", "travellers", "{{travellerId}}"] } }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const r = pm.response.json();",
              "if (r.id) pm.collectionVariables.set('bookingId', r.id);",
              "if (r.bookingNo) pm.collectionVariables.set('bookingRef', r.bookingNo);"
            ], "type": "text/javascript" } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerToken}}" }] },
            "body": { "mode": "raw", "raw": "{\n  \"tripId\": \"{{tripId}}\",\n  \"originId\": \"lhe\",\n  \"destinationId\": \"isb\",\n  \"seats\": [\"3A\", \"3B\"],\n  \"passengers\": [\n    { \"name\": \"Ali Raza\", \"gender\": \"M\", \"seatLabel\": \"3A\" },\n    { \"name\": \"Sara Ali\", \"gender\": \"F\", \"seatLabel\": \"3B\" }\n  ],\n  \"contact\": { \"name\": \"Ali Raza\", \"cnic\": \"3520112345671\", \"phone\": \"{{bookerPhone}}\", \"email\": \"ali@example.com\" },\n  \"paymentMethod\": \"Easypaisa\"\n}" },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] },
            "description": "Guest checkout works without a token; sending {{customerToken}} links the booking to the account. originId/destinationId drive correct segment pricing on multi-stop routes."
          }
        },
        {
          "name": "My bookings",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{customerToken}}" }] },
            "url": { "raw": "{{baseUrl}}/bookings/mine", "host": ["{{baseUrl}}"], "path": ["bookings", "mine"] },
            "description": "Returns bookings linked to the account AND any guest bookings made with the account's mobile number."
          }
        },
        {
          "name": "Lookup booking (guest)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings/lookup?ref={{bookingRef}}&phone={{bookerPhone}}",
              "host": ["{{baseUrl}}"],
              "path": ["bookings", "lookup"],
              "query": [
                { "key": "ref", "value": "{{bookingRef}}" },
                { "key": "phone", "value": "{{bookerPhone}}" }
              ]
            },
            "description": "PII-guarded: requires both the booking reference and the booker's mobile number."
          }
        },
        {
          "name": "Get booking (e-ticket) by id",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}"] } }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "cancel"] },
            "description": "Releases the seats and credits the fare to the customer's wallet (if the booking is linked to an account)."
          }
        }
      ]
    },
