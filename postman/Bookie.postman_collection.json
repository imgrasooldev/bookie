    {
      "name": "Super admin (/sa)",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
      "description": "All /sa endpoints require a token whose user has the 'admin' role. Log in via Auth > Login with an admin account and copy its token into {{adminToken}}.",
      "item": [
        {
          "name": "List operators",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/sa/operators?status=all&page=1", "host": ["{{baseUrl}}"], "path": ["sa", "operators"], "query": [{ "key": "status", "value": "all" }, { "key": "page", "value": "1" }] } }
