          "request": { "method": "DELETE", "header": [], "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}" }] }, "url": { "raw": "{{baseUrl}}/operator/vehicles/:id", "host": ["{{baseUrl}}"], "path": ["operator", "vehicles", ":id"] } }
        },
        {
          "name": "Operator bookings",
          "request": { "method": "GET", "header": [], "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}" }] }, "url": { "raw": "{{baseUrl}}/operator/bookings", "host": ["{{baseUrl}}"], "path": ["operator", "bookings"] } }
        },
        {
