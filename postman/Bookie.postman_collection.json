        },
        {
          "name": "List my trips",
          "request": { "method": "GET", "header": [], "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}" }] }, "url": { "raw": "{{baseUrl}}/operator/trips", "host": ["{{baseUrl}}"], "path": ["operator", "trips"] } }
