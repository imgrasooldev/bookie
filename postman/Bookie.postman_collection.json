          "request": { "method": "DELETE", "header": [], "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}" }] }, "url": { "raw": "{{baseUrl}}/operator/trips/{{tripId}}", "host": ["{{baseUrl}}"], "path": ["operator", "trips", "{{tripId}}"] } }
        },
        {
          "name": "List vehicles",
          "request": { "method": "GET", "header": [], "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{operatorToken}}" }] }, "url": { "raw": "{{baseUrl}}/operator/vehicles", "host": ["{{baseUrl}}"], "path": ["operator", "vehicles"] } }
